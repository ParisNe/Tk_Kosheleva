<Window x:Class="Tk_Kosheleva.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tk_Kosheleva"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель: ввод коэффициентов -->
        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" BorderBrush="Gray" BorderThickness="1" 
                Margin="5" Padding="10" CornerRadius="8" Height="160">
            <StackPanel>
                <TextBlock Text="Введите коэффициенты" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="a =" Width="30" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtA" Width="100" Margin="5,0" Text="0" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="b =" Width="30" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtB" Width="100" Margin="5,0" Text="0" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="c =" Width="30" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtC" Width="100" Margin="5,0" Text="0" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- выбор вида уравнения -->
        <Border Grid.Row="0" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" 
                Margin="5" Padding="10" CornerRadius="8" Height="160">
            <StackPanel>
                <TextBlock Text="Вид уравнения" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                <RadioButton x:Name="rbLinear" Content="Линейное" GroupName="EquationType" 
                             IsChecked="True" Margin="0,5" Checked="EquationType_Changed"/>
                <RadioButton x:Name="rbQuadratic" Content="Квадратное" GroupName="EquationType" 
                             Margin="0,5" Checked="EquationType_Changed"/>
            </StackPanel>
        </Border>

        <!-- Блок с результатом -->
        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" BorderBrush="Gray" BorderThickness="1" 
                Margin="5,20,5,5" Padding="10" CornerRadius="8" Background="#F0F0F0">
            <StackPanel>
                <TextBlock Text="Решение уравнения" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <TextBlock x:Name="txtResult" Text="(не вычислено)" FontSize="13" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Кнопка вычисления -->
        <Button x:Name="btnCalculate" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                Content="Вычислить" Width="120" Height="35" HorizontalAlignment="Center"
                Margin="5" Click="BtnCalculate_Click" FontWeight="Bold" FontSize="14"/>

        <!-- Дополнительная информация -->
        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                   Text="Формулы: линейное → a·x + b = 0; квадратное → a·x² + b·x + c = 0" 
                   FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="5"/>
    </Grid>
</Window>
